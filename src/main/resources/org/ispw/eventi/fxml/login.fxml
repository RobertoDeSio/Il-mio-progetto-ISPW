<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox prefHeight="700.0" prefWidth="1000.0" styleClass="main-container" stylesheets="@../style/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <children>

        <!-- Bottone indietro in alto a sinistra -->
        <HBox style="-fx-padding: 20 0 0 40;">
            <children>
                <Button text="← Torna alla Home"
                        onAction="#handleHome"
                        style="-fx-background-color: transparent; -fx-text-fill: #64748B; -fx-font-size: 13px; -fx-cursor: hand; -fx-padding: 0;"/>
            </children>
        </HBox>

        <!-- Card centrata -->
        <VBox alignment="CENTER" VBox.vgrow="ALWAYS">
            <children>
                <VBox alignment="CENTER" maxWidth="400.0" spacing="20.0" styleClass="card-white">
                    <padding><Insets top="40" right="40" bottom="40" left="40" /></padding>
                    <children>
                        <Label styleClass="hero-title-black" text="Accedi" />

                        <VBox spacing="10.0" alignment="CENTER_LEFT">
                            <Label text="Email" styleClass="form-label" />
                            <TextField fx:id="fieldEmail" promptText="La tua email" styleClass="form-input" />
                        </VBox>

                        <VBox spacing="10.0" alignment="CENTER_LEFT">
                            <Label text="Password" styleClass="form-label" />
                            <PasswordField fx:id="fieldPassword" promptText="La tua password" styleClass="form-input" />
                        </VBox>

                        <Label fx:id="labelErrore" styleClass="label-errore"
                               text="" wrapText="true" maxWidth="320.0" />

                        <Button styleClass="btn-blue" text="Accedi" prefWidth="200.0" onAction="#handleLogin"/>

                        <HBox alignment="CENTER" spacing="5.0">
                            <Label text="Non hai un account?" />
                            <Button text="Registrati" styleClass="link-button" onAction="#handleRegistrati"/>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>

    </children>
</VBox>
