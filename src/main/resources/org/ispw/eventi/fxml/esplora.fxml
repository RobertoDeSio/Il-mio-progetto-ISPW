<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="TOP_CENTER"
      prefHeight="700.0"
      prefWidth="1000.0"
      styleClass="main-container"
      stylesheets="@../style/style.css"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1">

    <children>

        <!-- NAVBAR CLIENTE -->
        <HBox fx:id="navbarCliente" alignment="CENTER_LEFT" prefHeight="70.0" spacing="20.0" styleClass="navbar">
            <padding><Insets left="50.0" right="50.0"/></padding>
            <children>
                <Label styleClass="logo-text" text="Weekender"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnNavHome"         onAction="#tornaIndietro"    styleClass="nav-link" text="Home"/>
                <Button fx:id="btnNavEsplora"      onAction="#handleEsplora"    styleClass="nav-link" text="Esplora Attività"/>
                <Button fx:id="btnNavPrenotazioni" onAction="#vaiAPrenotazioni" styleClass="nav-link" text="Le Mie Prenotazioni"/>
                <Region prefWidth="10.0"/>
                <HBox alignment="CENTER" spacing="8">
                    <children>
                        <Label text="👤" style="-fx-font-size: 14px;"/>
                        <Label fx:id="labelNomeUtenteCliente" style="-fx-font-size: 14px; -fx-text-fill: #1E293B;"/>
                        <Label text="CLIENT"
                               style="-fx-background-color: #DBEAFE; -fx-text-fill: #2563EB;
                                      -fx-font-size: 10px; -fx-font-weight: BOLD;
                                      -fx-background-radius: 4; -fx-padding: 2 6 2 6;"/>
                    </children>
                </HBox>
                <Button onAction="#handleLogout" styleClass="btn-outline" text="→"/>
            </children>
        </HBox>

        <!-- NAVBAR ORGANIZZATORE -->
        <HBox fx:id="navbarOrganizzatore" alignment="CENTER_LEFT" prefHeight="70.0" spacing="20.0" styleClass="navbar" visible="false" managed="false">
            <padding><Insets left="50.0" right="50.0"/></padding>
            <children>
                <Label styleClass="logo-text" text="Weekender"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnNavHomeOrg"      onAction="#tornaIndietro"         styleClass="nav-link" text="Home"/>
                <Button fx:id="btnNavEsploraOrg"   onAction="#handleEsplora"         styleClass="nav-link" text="Esplora Attività"/>
                <Button                             onAction="#handleCreaEvento"      styleClass="nav-link" text="Crea Evento"/>
                <Button fx:id="btnNavGestioneOrg"  onAction="#handleGestioneRichieste" styleClass="nav-link" text="Gestione Richieste"/>
                <Region prefWidth="10.0"/>
                <HBox alignment="CENTER" spacing="8">
                    <children>
                        <Label text="👤" style="-fx-font-size: 14px;"/>
                        <Label fx:id="labelNomeUtenteOrg" style="-fx-font-size: 14px; -fx-text-fill: #1E293B;"/>
                        <Label text="ORGANIZER"
                               style="-fx-background-color: #DBEAFE; -fx-text-fill: #2563EB;
                                      -fx-font-size: 10px; -fx-font-weight: BOLD;
                                      -fx-background-radius: 4; -fx-padding: 2 6 2 6;"/>
                    </children>
                </HBox>
                <Button onAction="#handleLogout" styleClass="btn-outline" text="→"/>
            </children>
        </HBox>

        <!-- CONTENUTO -->
        <VBox spacing="20.0" style="-fx-padding: 30 50;">
            <children>
                <HBox alignment="CENTER_LEFT">
                    <children>
                        <VBox>
                            <children>
                                <Label styleClass="hero-title-black" text="Prossimi Eventi"/>
                                <Label styleClass="hero-subtitle" text="Esplora le migliori attività scelte per te."/>
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <HBox alignment="CENTER" spacing="5.0" styleClass="filter-container">
                            <children>
                                <Button fx:id="btnFiltroAll"      onAction="#handleFiltroAll"      styleClass="filter-button-active" text="All"/>
                                <Button fx:id="btnFiltroMoto"     onAction="#handleFiltroMoto"     styleClass="nav-link" text="Moto"/>
                                <Button fx:id="btnFiltroBoat"     onAction="#handleFiltroBoat"     styleClass="nav-link" text="Boat"/>
                                <Button fx:id="btnFiltroTrekking" onAction="#handleFiltroTrekking" styleClass="nav-link" text="Trekking"/>
                            </children>
                        </HBox>
                    </children>
                </HBox>
                <FlowPane fx:id="flowPaneEventi" hgap="30.0" vgap="30.0"/>
            </children>
        </VBox>
    </children>
</VBox>
